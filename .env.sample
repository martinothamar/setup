# Optional local setup settings.
# Copy this file to .env and fill values there. Never commit .env.

# CachyOS Tailscale setup.
# Leave these empty for the normal interactive `sudo tailscale up` flow.
SETUP_TAILSCALE_AUTHKEY=
SETUP_TAILSCALE_HOSTNAME=
SETUP_TAILSCALE_ACCEPT_DNS=
SETUP_TAILSCALE_ADVERTISE_EXIT_NODE=true

# OpenCode vLLM provider.
# Example: SETUP_OPENCODE_VLLM_BASE_URL=https://your-private-vllm-host.example.com:18000/v1
SETUP_OPENCODE_VLLM_BASE_URL=http://127.0.0.1:8000/v1
SETUP_OPENCODE_VLLM_API_KEY=local-vllm
